# AlphaVantage API (free tier: 25 requests/day)
# Premium required for multi-user production: https://alphavantage.co/premium/
ALPHAVANTAGE_API_KEY=your_alphavantage_key_here

# Google Gemini API
GOOGLE_API_KEY=your_google_api_key_here

# Internal service URL (set automatically by docker-compose)
# Do not change this unless running outside Docker
SDE_ENGINE_URL=http://sde_engine:8000/simulate_climate_risk
